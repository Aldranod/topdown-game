[node name="DialogText3" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "Herbs, resin and goat shit. Home sweet home.
"
npc_info = ExtResource("11_yl0sm")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "Daingne-Bein is still two days of march from here.
"
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText2" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "Today, however, I'm counting on a roof over my head and something warm to eat."
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText5" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "Aye. We can stay in courier station tonight. It is nearby as I remember.
"
npc_info = ExtResource("11_yl0sm")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText8" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "Agreed but first...
"
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText6" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "I don't like silence in this woods and I don't see chimney smoke. 

"
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText7" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "<player>, go and check this station. The squad will wait here for your report."
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogCutsceneCamera1" type="Node" parent="NPC3/DialogInteraction"]
