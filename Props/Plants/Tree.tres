code = "shader_type canvas_item;
render_mode blend_mix;

instance uniform float RandomStrength;



void vertex() {
// Input:5
	vec2 n_out5p0 = VERTEX;


// VectorDecompose:6
	float n_out6p0 = n_out5p0.x;
	float n_out6p1 = n_out5p0.y;


// Input:2
	vec2 n_out2p0 = UV;
	float n_out2p2 = n_out2p0.g;


	float n_out3p0;
// Remap:3
	float n_in3p1 = 0.00000;
	float n_in3p2 = 0.70000;
	float n_in3p3 = 1.00000;
	float n_in3p4 = 0.00000;
	{
		float __input_range = n_in3p2 - n_in3p1;
		float __output_range = n_in3p4 - n_in3p3;
		n_out3p0 = n_in3p3 + __output_range * ((n_out2p2 - n_in3p1) / __input_range);
	}


// Input:9
	float n_out9p0 = TIME;


// FloatParameter:11
	float n_out11p0 = RandomStrength;


// FloatOp:10
	float n_out10p0 = n_out9p0 * n_out11p0;


// FloatFunc:12
	float n_out12p0 = sin(n_out10p0);


// FloatOp:4
	float n_out4p0 = n_out3p0 * n_out12p0;


// FloatOp:7
	float n_out7p0 = n_out6p0 + n_out4p0;


// VectorCompose:8
	vec2 n_out8p0 = vec2(n_out7p0, n_out6p1);


// Output:0
	VERTEX = n_out8p0;


}

void fragment() {
// Input:5
	vec2 n_out5p0 = VERTEX;


// VectorDecompose:6
	float n_out6p0 = n_out5p0.x;
	float n_out6p1 = n_out5p0.y;


// Input:2
	vec2 n_out2p0 = UV;
	float n_out2p2 = n_out2p0.g;


	float n_out3p0;
// Remap:3
	float n_in3p1 = 0.00000;
	float n_in3p2 = 0.70000;
	float n_in3p3 = 1.00000;
	float n_in3p4 = 0.00000;
	{
		float __input_range = n_in3p2 - n_in3p1;
		float __output_range = n_in3p4 - n_in3p3;
		n_out3p0 = n_in3p3 + __output_range * ((n_out2p2 - n_in3p1) / __input_range);
	}


// FloatOp:4
	float n_in4p1 = 10.00000;
	float n_out4p0 = n_out3p0 * n_in4p1;


// FloatOp:7
	float n_out7p0 = n_out6p0 + n_out4p0;


// VectorCompose:8
	vec2 n_out8p0 = vec2(n_out7p0, n_out6p1);


// Output:0
	NORMAL = vec3(n_out8p0, 0.0);


}
