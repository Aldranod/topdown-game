[node name="DialogBranch4" type="Node" parent="NPC/QuestActivatedSwitch2/DialogInteraction/DialogChoice"]
script = ExtResource("7_cap4d")
text = "Can you tell me more about this temple?"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText7" type="Node" parent="NPC/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch4"]
script = ExtResource("5_rm5k1")
text = "As I said, Toshek told me once about it. He said that it is hidden somewhere near rocks."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText8" type="Node" parent="NPC/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch4"]
