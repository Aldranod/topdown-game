[node name="DialogInteraction" parent="NPCs/Thaaw/QuestActivatedSwitch" instance=ExtResource("9_stv3e")]

[node name="DialogText4" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "Yes, soldier?"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogChoice" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction"]
script = ExtResource("16_r1rbg")
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://fshksdm1ixai"

[node name="DialogBranch2" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice"]
script = ExtResource("17_dy3m7")
text = "Where is this station exactly ?"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText2" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("10_rlbco")
text = "Station should be to the west, just follow path in woods."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText3" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("10_rlbco")
text = "And be careful. It is too quiet here."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogBranch" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice"]
script = ExtResource("17_dy3m7")
text = "Shouldn't we see any patrols from Daingne-Bein?"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText2" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "We should. Mountain guard patrols this woods since always."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText3" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "That's why I'm worried about station situation"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogBranch3" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice"]
script = ExtResource("17_dy3m7")
text = "I have to go"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText3" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("10_rlbco")
text = "Bye"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

