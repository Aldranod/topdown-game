[node name="DialogText" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "Bloody greenskins!"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText2" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "We've almost made it!"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText3" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "What happend!"
npc_info = ExtResource("29_iwdc0")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText4" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "Ambush...
there were too many of them...
Damn! That... hurt
"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText5" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "That wound is deep.
Can you walk?"
npc_info = ExtResource("29_iwdc0")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText6" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("10_rlbco")
text = "Barely.
Listen, we have to split...
It is our only chance.
"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogChoice" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction"]
script = ExtResource("16_r1rbg")
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://fshksdm1ixai"

[node name="DialogBranch" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice"]
script = ExtResource("17_dy3m7")
text = "Sir. I have to disagree..."
npc_info = ExtResource("29_iwdc0")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText6" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "I will only slow you down...
but if we split... maybe we can outmanouver them!
"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText9" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "But Sir!... 
"
npc_info = ExtResource("29_iwdc0")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText7" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "That's an order soldier!"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText10" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "Now listen...
Behind courier station, there is a hidden path near the foot of the rocks."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText8" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "Maybe greenskins doesn't know about it."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText11" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("10_rlbco")
text = "With gods help we will meet again in Daingne-Bein.
Now hurry! Enemies are close!"
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogBranch2" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice"]
script = ExtResource("17_dy3m7")
text = "Yes sir!"
npc_info = ExtResource("29_iwdc0")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText6" type="Node" parent="NPCs/Thaaw/QuestActivatedSwitch2/DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("10_rlbco")
text = "Very well soldier!
Behind courier station, there is a hidden path near the foot of the rocks."
npc_info = ExtResource("8_6mffx")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

