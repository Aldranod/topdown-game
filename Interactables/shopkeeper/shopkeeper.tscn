[node name="DialogInteraction" parent="NPC/QuestActivatedSwitch" instance=ExtResource("10_w5t0x")]

[node name="DialogText" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction"]
script = ExtResource("5_rm5k1")
text = "Thank you for taking care of these greenskins!"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogChoice" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction"]
script = ExtResource("6_l65jf")
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://fshksdm1ixai"

[node name="DialogBranch3" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice"]
script = ExtResource("7_cap4d")
text = "What's going on here?"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "I don't understand this either. Goblins on this side of the mountains? Right under the noses of the brave mountain guard?"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText2" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Anyway, two days ago they suddenly appeared in my orchard and started ransacking it! "
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText3" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "After a moment, they attacked me, but I managed to barricade myself inside. Thanks again for your help. "
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText4" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "I would have starved to death here if it weren't for you."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogChoice" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_l65jf")
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://fshksdm1ixai"

[node name="DialogBranch" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice"]
script = ExtResource("7_cap4d")
text = "Does anyone still live here?"
npc_info = ExtResource("9_l65jf")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("5_rm5k1")
text = "Well, Toshek lives nearby to the west. He's a hunter. But considering he didn't come to my aid, I guess the Goblins got him first"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText2" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("5_rm5k1")
text = "There is also courier outpost to the east but you've probably already been there."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogBranch3" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice"]
script = ExtResource("7_cap4d")
text = "I need to get to Daingne-Bean. Can you help me?"
npc_info = ExtResource("9_l65jf")
metadata/_custom_type_script = "uid://c5uj5hel8n7vv"

[node name="DialogText" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Daingne-Bean aye?. Are you returning from that expedition against the rebels? Has the rebellion been crushed?"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText2" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Yes...
I don't want to talk about this.
So do you know way to Daingne-Bean from here?"
npc_info = ExtResource("9_l65jf")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText3" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "This part of the forest is cut off from the world. I don't know of any way through the mountains. "
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText10" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "You'll have to return to the courier outpost and cross the river there."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText6" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Bridge on the river have been destroyed."
npc_info = ExtResource("9_l65jf")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText5" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Well, that's a mess. It looks like you will stuck here for some time."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText4" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Really no other way around?"
npc_info = ExtResource("9_l65jf")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText7" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Well...
Toshek told me once about  an old abandoned temple carved into a mountain wall."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText8" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "However, he never examined it and I don't blame him. Who knows what lurks in darkness here?"
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogText9" type="Node" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("5_rm5k1")
text = "Anyway I don't know its location so you'll have to find it on your own."
npc_info = ExtResource("3_f4o7l")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="QuestAdvanceTrigger" type="Node2D" parent="NPC/QuestActivatedSwitch/DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch3"]
script = ExtResource("12_cyuks")
signal_name = "selected"
