[node name="DialogText4" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("10_kk2qx")
text = "You fell it?
"
npc_info = ExtResource("8_l5ond")
metadata/_custom_type_script = "uid://doa5j8sxy5b7q"

[node name="DialogCutscene4" type="Node" parent="NPC3/DialogInteraction"]
script = ExtResource("20_ddi7v")
playback_mode = 0
metadata/_custom_type_script = "uid://bqyb0s0d404xv"

